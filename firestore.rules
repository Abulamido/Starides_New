rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isRider() {
      return isAuthenticated();
    }
    
    // Vendors collection - public read, owner write, admin full access
    match /vendors/{vendorId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && 
        vendorId == request.auth.uid);
    }
    
    // Products collection - public read, vendor owner write, admin full access
    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && 
        resource.data.vendorId == request.auth.uid);
    }
    
    // Orders collection
    match /orders/{orderId} {
      // Allow any authenticated user to read orders
      // This is necessary because riders need to see available deliveries
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated();
      
      allow update: if isAdmin() || (isAuthenticated() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.vendorId == request.auth.uid ||
        resource.data.riderId == request.auth.uid ||
        // Allow riders to claim orders (update riderId) - OLD status values
        (resource.data.status == 'Shipped' && request.resource.data.riderId == request.auth.uid) ||
        (resource.data.status == 'Accepted' && request.resource.data.riderId == request.auth.uid) ||
        (resource.data.status == 'Processing' && request.resource.data.riderId == request.auth.uid) ||
        // Allow riders to claim orders (update riderId) - NEW status values
        (resource.data.status == 'Ready for Pickup' && request.resource.data.riderId == request.auth.uid) ||
        (resource.data.status == 'Preparing' && request.resource.data.riderId == request.auth.uid) ||
        (resource.data.status == 'New Order' && request.resource.data.riderId == request.auth.uid) ||
        (resource.data.status == 'Pending Acceptance' && request.resource.data.riderId == request.auth.uid) ||
        // Allow riders to update location on active deliveries - OLD status
        (resource.data.riderId == request.auth.uid && 
         resource.data.status == 'Out for Delivery' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['riderLocation', 'eta', 'updatedAt'])) ||
        // Allow riders to update location on active deliveries - NEW status
        (resource.data.riderId == request.auth.uid && 
         resource.data.status == 'In Transit' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['riderLocation', 'eta', 'updatedAt']))
      ));
      
      allow delete: if isAdmin();
    }
    
    // Users collection - admins can read all users
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
      
      match /savedCards/{cardId} {
        allow read: if isOwner(userId);
        allow write: if false; // Only server can write
      }

      match /addresses/{addressId} {
        allow read, write: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Customers collection - admins can read all
    match /customers/{customerId} {
      allow read: if isAdmin() || isOwner(customerId);
      allow write: if isAdmin() || isOwner(customerId);
    }
    
    // Riders collection - admins can read all
    match /riders/{riderId} {
      allow read: if isAdmin() || isOwner(riderId);
      allow write: if isAdmin() || isOwner(riderId);
    }

    // Wallets collection - users can only read their own wallet, only server can write
    match /wallets/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only server-side functions can write
    }

    // Transactions collection - users can only read their own transactions, only server can write
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false; // Only server-side functions can write
    }

    // Payouts collection
    match /payouts/{payoutId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
