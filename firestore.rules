rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own data
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Authenticated users can read products and vendors
    match /products/{productId} {
      allow read: if request.auth != null;
    }
    match /vendors/{vendorId} {
      allow read: if request.auth != null;
    }

    // Rules for Orders
    match /orders/{orderId} {
      // Customers can create orders and read their own orders
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource.data.customerId == request.auth.uid || resource.data.vendorId == request.auth.uid);
      
      // Admins, Vendors, and Riders can update orders
      allow update: if request.auth != null; 
    }
    
    // Allow admin reads/writes on all other collections for management
    // This requires a custom claim, which we will set up later.
    // For now, we will allow any authenticated user to perform these actions
    // during development.
    match /riders/{riderId} {
      allow read, write: if request.auth != null;
    }
     match /customers/{customerId} {
      allow read, write: if request.auth != null;
    }

    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
