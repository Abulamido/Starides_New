/**
 * @file Firestore Security Rules for a Multi-Role Marketplace
 * @core_philosophy This ruleset enforces a strict user-ownership model for user-specific data and employs role-based access control where appropriate. It prioritizes security and efficiency by denormalizing data necessary for authorization directly onto the documents being secured, avoiding costly `get()` calls.
 * @data_structure
 *   - `/users/{userId}`: Stores user profiles, keyed by Firebase Authentication UID.  User documents contain a `role` field crucial for authorization.
 *   - `/customers/{customerId}`: Stores customer-specific data.
 *   - `/vendors/{vendorId}`: Stores vendor-specific data.
 *   - `/riders/{riderId}`: Stores rider-specific data.
 *   - `/roles_admin/{userId}`: Presence of a document indicates admin privileges.
 *   - `/products/{productId}`: Stores product information.
 *   - `/orders/{orderId}`: Stores order information, including `customerId` and `vendorId` for authorization.
 * @key_security_decisions
 *   - User listing is generally disallowed except where explicitly needed and securely implemented.
 *   - The `roles_admin` collection grants admin privileges based solely on document existence.
 *   - Public read access is not generally granted, except where explicitly intended and secured with owner-only writes.
 * @denormalization_for_authorization
 *   - Order documents include `customerId` and `vendorId` to allow direct authorization checks without additional reads.
 * @structural_segregation
 *   - User profiles and role assignments are stored in separate collections to maintain clear separation of concerns and consistent security policies.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    match /customers/{customerId} {
       allow read, write: if isSignedIn();
    }

    match /vendors/{vendorId} {
       allow read, write: if isSignedIn();
    }

    match /riders/{riderId} {
       allow read, write: if isSignedIn();
    }

    match /roles_admin/{userId} {
       allow read, write: if isSignedIn();
    }

    match /products/{productId} {
       allow read, write: if isSignedIn();
    }

    match /orders/{orderId} {
       allow read, write: if isSignedIn();
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

    function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }

  function isCustomerOwner() {
    return request.auth.uid == resource.data.userId;
  }

      function isExistingCustomerOwner() {
    return isCustomerOwner() && resource != null;
  }

  function isVendorOwner() {
    return request.auth.uid == resource.data.userId;
  }

        function isExistingVendorOwner() {
    return isVendorOwner() && resource != null;
  }

  function isRiderOwner() {
    return request.auth.uid == resource.data.userId;
  }

          function isExistingRiderOwner() {
    return isRiderOwner() && resource != null;
  }

  function isAdmin() {
    return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
  }

  function isCustomer(customerId) {
        return request.auth.uid == customerId;
  }

  function isVendor(vendorId) {
        return request.auth.uid == vendorId;
  }

  function isExistingCustomer(customerId) {
    return isCustomer(customerId) && resource != null;
  }

  function isExistingVendor(vendorId) {
    return isVendor(vendorId) && resource != null;
  }
}
